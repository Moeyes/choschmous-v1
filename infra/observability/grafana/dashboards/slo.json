{
  "uid": "moeys-slo",
  "title": "MOEYS SLO \u2014 Error Budget Burn (CHOS-504)",
  "tags": [
    "moeys",
    "slo"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability 1h error ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.006
              },
              {
                "color": "red",
                "value": 0.0144
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_availability_errors:ratio_rate1h"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Latency 1h too-slow ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.06
              },
              {
                "color": "red",
                "value": 0.144
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_latency_errors:ratio_rate1h"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avail burn rate (x)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_availability_errors:ratio_rate1h / 0.001"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latency burn rate (x)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_latency_errors:ratio_rate1h / 0.01"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Availability error ratio (multi-window)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_availability_errors:ratio_rate5m",
          "legendFormat": "5m"
        },
        {
          "refId": "B",
          "expr": "job:slo_availability_errors:ratio_rate1h",
          "legendFormat": "1h"
        },
        {
          "refId": "C",
          "expr": "job:slo_availability_errors:ratio_rate6h",
          "legendFormat": "6h"
        },
        {
          "refId": "D",
          "expr": "job:slo_availability_errors:ratio_rate1d",
          "legendFormat": "1d"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency too-slow ratio (multi-window)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_latency_errors:ratio_rate5m",
          "legendFormat": "5m"
        },
        {
          "refId": "B",
          "expr": "job:slo_latency_errors:ratio_rate1h",
          "legendFormat": "1h"
        },
        {
          "refId": "C",
          "expr": "job:slo_latency_errors:ratio_rate6h",
          "legendFormat": "6h"
        }
      ]
    }
  ]
}
