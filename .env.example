# ── Production environment template for the moeys stack ─────────────────────
# Copy to .env and fill in real values:  cp .env.example .env
# Generate each JWT secret with:          openssl rand -hex 32

ENVIRONMENT=production

DB_USER=postgres
DB_PASS=change-me-strong-db-password
DB_NAME=moeys

# Must be >= 32 chars and NOT a placeholder, or the backend refuses to start.
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=

BACKEND_CORS_ORIGINS=http://localhost:3001
