# ── Production environment template for the moeys stack ─────────────────────
# Consumed by docker-compose.prod.yml. Copy and fill in real values:
#     cp .env.example .env.production   # then edit .env.production
# Generate each JWT secret with:  openssl rand -hex 32   (>= 32 chars, unique)
#
# .env.production is gitignored — never commit real secrets.

ENVIRONMENT=production

# ── Postgres ────────────────────────────────────────────────────────────────
DB_USER=moeys
DB_PASS=change-me-strong-db-password
DB_NAME=moeys

# ── Redis (password-protected in prod) ──────────────────────────────────────
REDIS_PASS=change-me-strong-redis-password

# ── JWT signing secrets ─────────────────────────────────────────────────────
# Must be >= 32 chars and NOT a known placeholder, or the backend refuses to
# start (see _INSECURE_JWT_SECRETS in backend/core/config.py).
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=

# ── Public origins / URLs ───────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API.
BACKEND_CORS_ORIGINS=https://REPLACE-WITH-REAL-DOMAIN
# REQUIRED in prod: the public https URL, baked into the frontend bundle.
NEXT_PUBLIC_APP_URL=https://REPLACE-WITH-REAL-DOMAIN

# ── Tuning ──────────────────────────────────────────────────────────────────
WEB_CONCURRENCY=2
