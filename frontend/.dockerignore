# Keep the build context tiny — node_modules (817M) and .next (4.8G) must never
# be sent to the daemon or copied over the in-image install (musl vs glibc).
node_modules
.next
.git
Dockerfile
.dockerignore

# Local env only — keep committed .env / .env.production for Next build-time vars
.env.local
.env*.local

# Source archives — never ship these into the build context
*.zip

# Test / tooling artifacts
e2e/.auth
e2e/screenshots
e2e/test-results
e2e/playwright-report
coverage
*.tsbuildinfo
npm-debug.log*