# Canonical npm registry. Pinned to match the Dockerfile, which sets
# npm_config_registry=https://registry.npmjs.org/ (the env var wins in-image,
# so a divergent .npmrc here would silently disagree with container builds).
# If you need the SE-Asia mirror for slow local installs, flip BOTH this line
# and the Dockerfile to https://registry.npmmirror.com/ together.
registry=https://registry.npmjs.org/

# Resilience for slow / high-latency connections to the npm registry.
# The Docker build (and local installs) were failing with mass ETIMEDOUT while
# fetching from registry.npmjs.org. Lower concurrency stops a weak link from
# being saturated; longer timeouts + more retries ride out transient drops.
network-concurrency=4
fetch-retries=6
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=180000
fetch-timeout=600000
