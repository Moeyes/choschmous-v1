DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moeys

# Read path (CHOS-301): dashboards / reports / list reads are routed to read
# replicas via PgBouncer. Leave BOTH unset for single-DB local dev — the read
# session then transparently reuses the primary. In deployed envs set ONE of:
#   DATABASE_READ_URL=postgresql+asyncpg://USER:PASS@pgbouncer.<ns>.svc:6432/moeys
# or the host/port pair (same credentials/db as the primary):
#   DB_READ_HOST=pgbouncer.<ns>.svc
#   DB_READ_PORT=6432
# DATABASE_READ_URL=
# DB_READ_HOST=
# DB_READ_PORT=

# Generate a real one with: openssl rand -hex 32  (must be >= 32 chars)
JWT_SECRET_KEY=REPLACE_ME_WITH_A_32_CHAR_RANDOM_SECRET
ENVIRONMENT=local
# Note: list may be parsed either as CSV or Python list; both are accepted.
BACKEND_CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003,http://localhost:3000,http://localhost:3001

# Optional — uncomment to enable
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# SENTRY_DSN=
